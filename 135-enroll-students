public void enrollStudents(List<String> emails, String className) {
    // code here
    List<apxio__Student__c> students = [SELECT Id, Name 
                                        FROM apxio__Student__c
                                        WHERE apxio__Email__c IN :emails];
    List<apxio__Class__c> classes = [SELECT Id, Name 
                                     FROM apxio__Class__c
                                     WHERE Name = :className
                                     LIMIT 1];
    
    if (students.isEmpty() || classes.isEmpty()) return;

    List<apxio__Class_Enrollment__c> enrollments = new List<apxio__Class_Enrollment__c>();

    for (apxio__Student__c s : students){
        enrollments.add(new apxio__Class_Enrollment__c(
            apxio__Student__c = s.Id,
            apxio__Offered_Class__c = classes[0].Id
        ));
    }

    insert enrollments;

}
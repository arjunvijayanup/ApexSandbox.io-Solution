public Id insertCourse(String name, String details, Integer credits) {
    // code here
    apxio__Course__c c = new apxio__Course__c(
        Name = name,
        apxio__Course_Details__c = details,
        apxio__Credits__c = String.valueOf(credits) // Converting integer to string for picklist
    );
    insert c;
    return c.id;
}
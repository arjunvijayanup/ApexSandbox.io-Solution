public String aOrAn(String word) {
    //code here
    String lower = word.toLowerCase();
    Boolean check = lower.startsWith('a') || 
                    lower.startsWith('e') ||
                    lower.startsWith('i') || 
                    lower.startsWith('o') || 
                    lower.startsWith('u');
    return (check ? 'an' : 'a') + ' ' + word;

}
public String registerStudent(String name, String phone, String email) {
    // code here
    apxio__Student__c s = new apxio__Student__c(
        Name = name, 
        apxio__Phone__c = phone,
        apxio__Email__c = email
    );

    insert s;

    apxio__Student__c s1 = [SELECT apxio__Registration_Number__c
                            FROM apxio__Student__c
                            WHERE ID = s.id LIMIT 1];
    
    return s1;
}
public String nameFromEmail(String email) {
    //code here
    List<String> arr = email.split('[.@]');
    String firstName = arr[0].substring(0,1).toUpperCase() + arr[0].substring(1).toLowerCase();
    String lastName =  arr[1].substring(0,1).toUpperCase() + arr[1].substring(1).toLowerCase();
    return firstName + ' ' + lastName;
}
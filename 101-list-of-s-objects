public List<sObject> getListOfsObject(List<Account> accounts, List<Contact> contacts)
{
    // code here
    if (accounts.isEmpty() || contacts.isEmpty()) return null;

    List<sObject> items = new List<sObject>();

    for (Account a : accounts){
        items.add(a);
    }
    for (Contact c : contacts){
        items.add(c);
    }
    return items;
}
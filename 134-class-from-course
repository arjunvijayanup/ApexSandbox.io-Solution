public Id classFromCourse(String courseName) {
    // code here
    List<apxio__Course__c> courses = [SELECT Id, Name
                                      FROM apxio__Course__c
                                      WHERE Name = :courseName
                                      LIMIT 1];

    
    if !courses.isEmpty() {

        apxio__Class__c c = new apxio__Class__c(
        Name = courseName,
        apxio__Course__c = courses[0].id
    );

    insert c;
    return c.id;

    }

    return;
    
}
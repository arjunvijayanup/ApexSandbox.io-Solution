public String changeTimeFormat(String strTime) {
    //code here
    List<String> splits = strTime.split(':');
    Integer hours = Integer.valueOf(splits[0]);
    Integer mins = Integer.valueOf(splits[1]);

    Time t = Time.newInstance(hours, mins, 0, 0);
    DateTime dt = DateTime.newInstance(Date.today(), t);

    return dt.format('h:mm a');


}
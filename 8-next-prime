public Integer nextPrime(Integer num) {
    //code here
    Integer prime = num + 1;
    while (True){
        Boolean isPrime = True;
        for (Integer i = 2; i < prime; i++){
            if (Math.mod(prime, i) == 0) {
                isPrime = False;
                break;
            }
        }
        if (isPrime) return prime;
        prime++;
    }
    return -1;
}
public List<Account> getAccounts(List<Account> accounts) {
    // code here
    if (accounts.isEmpty() || accounts == null) return null;
    
    List<AccountWrapper> wrappers = new List<AccountWrapper>();
    for (Account a: accounts){              //wrap
        wrappers.add(new AccountWrapper(a));
    }

    wrappers.sort();                 //sort

    List<Account> sorted = new List<Account>();
    for (AccountWrapper w: wrappers){
        sorted.add(w.acc);
    }

    return sorted;
}
// write extra class here 
public class AccountWrapper implements Comparable {
    public Account acc;

    public AccountWrapper(Account a) { 
        acc = a; 
    }

    public Integer compareTo(Object obj){
        AccountWrapper compareToAcc = (AccountWrapper) obj;
        if (acc.AnnualRevenue == compareToAcc.acc.AnnualRevenue) return 0;
        if (acc.AnnualRevenue < compareToAcc.acc.AnnualRevenue) return 1;
        return -1;
    }

}